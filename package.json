{
  "name": "vscode-fink",
  "categories": [
    "Programming Languages",
    "Debuggers",
    "Snippets"
  ],
  "version": "0.0.0-semantically-released",
  "license": "MIT",
  "displayName": "fink",
  "icon": "./build/pkg/images/icon.png",
  "description": "Language support for the ƒink programming language (https://github.com/fink-lang).",
  "engines": {
    "vscode": "^1.50.0"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:fink-lang/vscode-fink"
  },
  "bugs": "https://github.com/fink-lang/vscode-fink/issues",
  "homepage": "https://github.com/fink-lang/vscode-fink",
  "publisher": "fink",
  "main": "./build/pkg/extension.js",
  "browser": "./build/pkg/extension.js",
  "activationEvents": [
    "onLanguage:fink",
    "onDebug:fink"
  ],
  "contributes": {
    "commands": [
      {
        "command": "fink.reloadWasm",
        "title": "fink: Reload WASM"
      }
    ],
    "languages": [
      {
        "id": "fink",
        "aliases": [
          "fink"
        ],
        "extensions": [
          ".fnk"
        ],
        "firstLine": "^#!.*\\bfink",
        "configuration": "./build/pkg/languages/fink.language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "fink",
        "scopeName": "source.fink",
        "path": "./build/pkg/grammars/fink.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.fink": "fink"
        }
      },
      {
        "scopeName": "source.regexp.fink",
        "path": "./build/pkg/grammars/regex.tmLanguage.json"
      },
      {
        "scopeName": "markdown.fink.codeblock",
        "path": "./build/pkg/grammars/fink-md.tmLanguage.json",
        "injectTo": [
          "text.html.markdown",
          "source.fink"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.fink": "fink"
        }
      }
    ],
    "debuggers": [
      {
        "type": "fink",
        "label": "Fink",
        "configurationAttributes": {
          "launch": {
            "required": ["program"],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to the fink file to debug"
              },
              "stopOnEntry": {
                "type": "boolean",
                "description": "Pause before WASM runs",
                "default": false
              },
              "runtimeExecutable": {
                "type": "string",
                "description": "Path to the fink binary"
              }
            }
          }
        },
        "configurationSnippets": [
          {
            "label": "Fink: Debug",
            "description": "Debug a fink file via native DAP",
            "body": {
              "type": "fink",
              "request": "launch",
              "name": "Debug Fink",
              "program": "${file}"
            }
          }
        ]
      }
    ],
    "breakpoints": [
      {
        "language": "fink"
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "fink",
        "scopes": {
          "block-name": ["entity.name.namespace.fink"],
          "tag-left": ["entity.name.tag.left.fink"],
          "tag-right": ["entity.name.tag.right.fink"]
        }
      }
    ],
    "configuration": {
      "title": "fink",
      "properties": {
        "fink.packagePaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": ["pkgs"],
          "description": "Package search roots for resolving 'std/*', 'fink/*', and other package imports in go-to-definition. Each entry is a directory under which packages live as <root>/<pkg>/<path> (e.g. a checkout of fink's 'pkgs/' directory). Entries are tried in order; the first existing file wins. Each entry is absolute, or relative to the workspace folder. When empty, the FINK_PKGS environment variable (colon-separated) is used instead."
        }
      }
    }
  },
  "scripts": {},
  "devDependencies": {
    "@semantic-release/exec": "^7.0.0",
    "@types/vscode": "^1.50.0",
    "esbuild": "^0.28.0",
    "semantic-release": "^25.0.0",
    "semantic-release-vsce": "^6.0.0",
    "typescript": "^6.0.0"
  },
  "assets": {
    "brand": {
      "repo": "fink-lang/brand",
      "version": "v1.0.0",
      "url": "https://github.com/fink-lang/brand/releases/download/{version}/brand-assets.tar.gz",
      "dest": ".deps/brand"
    }
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  }
}
