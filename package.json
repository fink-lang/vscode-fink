{
  "name": "vscode-fink",
  "categories": [
    "Programming Languages",
    "Debuggers",
    "Snippets"
  ],
  "version": "0.0.0-semantically-released",
  "license": "MIT",
  "displayName": "fink",
  "icon": "images/icon.png",
  "description": "VSCode syntax highlighting for fink.",
  "engines": {
    "vscode": "^1.50.0"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:fink-lang/vscode-fink"
  },
  "bugs": "https://github.com/fink-lang/vscode-fink/issues",
  "homepage": "https://github.com/fink-lang/vscode-fink",
  "publisher": "fink",
  "main": "./build/pkg/extension.js",
  "browser": "./build/pkg/extension.js",
  "activationEvents": [
    "onLanguage:fink"
  ],
  "contributes": {
    "languages": [
      {
        "id": "fink",
        "aliases": [
          "fink",
          "fink+jsx"
        ],
        "extensions": [
          ".fnk"
        ],
        "firstLine": "^#!.*\\bfink",
        "configuration": "./build/pkg/languages/fink.language-configuration.json"
      },
      {
        "id": "fink-jsx",
        "configuration": "./build/pkg/languages/jsx.language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "fink",
        "scopeName": "source.fink",
        "path": "./build/pkg/grammars/fink.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.fink": "fink",
          "meta.embedded.jsx.fink": "fink-jsx"
        }
      },
      {
        "scopeName": "source.regexp.fink",
        "path": "./build/pkg/grammars/regex.tmLanguage.json"
      },
      {
        "scopeName": "source.jsx.fink",
        "path": "./build/pkg/grammars/jsx.tmLanguage.json"
      },
      {
        "scopeName": "markdown.fink.codeblock",
        "path": "./build/pkg/grammars/fink-md.tmLanguage.json",
        "injectTo": [
          "text.html.markdown",
          "source.fink"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.fink": "fink"
        }
      }
    ],
    "breakpoints": [
      {
        "language": "fink"
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "fink",
        "scopes": {
          "block-name": ["entity.name.namespace.fink"],
          "tag-left": ["entity.name.tag.left.fink"],
          "tag-right": ["entity.name.tag.right.fink"]
        }
      }
    ]
  },
  "scripts": {
    "clean": "rimraf ./build",
    "build": "npm run build:dir && npm run build:wasm && npm run build:ext && npm run build:grammars && npm run build:files && npm run build:languages",
    "build:dir": "mkdir -p ./build/pkg/grammars ./build/pkg/wasm",
    "build:wasm": "wasm-pack build --target web --weak-refs --out-dir build/pkg/wasm",
    "build:ext": "esbuild src/extension.ts --bundle --outfile=build/pkg/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "build:grammars": "node -r @fink/require-hook ./scripts/build-grammars.fnk",
    "build:files": "cp ./package.json ./README.md ./LICENSE ./build/pkg/",
    "build:languages": "cp -r ./languages ./build/pkg/",
    "dist:local": "cp -r build/pkg/* ~/.vscode/extensions/fink.vscode-fink-7.0.0/build/pkg/",
    "release": "semantic-release"
  },
  "devDependencies": {
    "@fink/cli": "^8.3.0",
    "@fink/js-interop": "^3.1.1",
    "@fink/larix": "^20.0.0",
    "@fink/loxia": "^24.1.2",
    "@fink/require-hook": "^6.2.0",
    "@fink/std-lib": "^8.5.0",
    "@semantic-release/exec": "^7.0.0",
    "@types/vscode": "^1.50.0",
    "esbuild": "^0.25.0",
    "semantic-release": "^25.0.0",
    "semantic-release-vsce": "^6.0.0",
    "typescript": "^5.4.0"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  }
}
